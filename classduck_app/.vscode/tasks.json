{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "run-classduck-web",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"chrome",
				"--web-port",
				"4088"
			],
			"isBackground": true
		},
		{
			"label": "run-classduck-on-emulator",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"emulator-5554"
			],
			"isBackground": true
		}
	]
}